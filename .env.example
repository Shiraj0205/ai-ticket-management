# Server
DATABASE_URL="postgresql://postgres:password@localhost:5432/ai_tickets"
PORT=3001
NODE_ENV=development

# Better Auth (generate secret with: openssl rand -base64 32)
BETTER_AUTH_SECRET="change-this-to-a-long-random-string-min-32-chars"
BETTER_AUTH_URL="http://localhost:5173"

# Client origin (used by CORS on the server)
CLIENT_URL="http://localhost:5173"

# Anthropic
ANTHROPIC_API_KEY="sk-ant-..."
